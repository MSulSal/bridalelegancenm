# Public base URL for canonical metadata (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional Formspree fallback (legacy)
FORMSPREE_APPOINTMENT_ENDPOINT=

# Square Payments API
# Use sandbox while testing:
# SQUARE_ENVIRONMENT=sandbox
SQUARE_ENVIRONMENT=sandbox
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox
NEXT_PUBLIC_SQUARE_APP_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_CURRENCY=USD
SQUARE_API_VERSION=2026-01-22

# Cloudinary (required to host inspiration photos so SMS can include them)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_APPOINTMENT_FOLDER=bridal-elegance-appointments

# Resend (notification email delivery)
RESEND_API_KEY=
APPOINTMENT_NOTIFICATION_EMAIL_FROM=appointments@bridalelegancenm.com
# comma-separated if multiple recipients
APPOINTMENT_NOTIFICATION_EMAIL_TO=

# Twilio (notification SMS/MMS delivery)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
APPOINTMENT_NOTIFICATION_SMS_TO=

